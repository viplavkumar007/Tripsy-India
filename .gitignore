## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Rider
.idea/

# MSTest test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build artifacts
*.dll
*.exe
*.pdb
*.cache
*.ilk
*.log
*.tmp
*.obj
*.iobj
*.ipdb
*.tlog
*.lastbuildstate
*.unsuccessfulbuild

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.assets.json
project.nuget.cache

# NuGet restore folders
.nuget/

# ASP.NET generated files
Generated_Code/
App_Data/

# IIS Express
.vs/config/applicationhost.config

# ClickOnce
publish/
*.publishsettings

# Azure
*.Publish.xml
*.pubxml
*.pubxml.user

# SQL Server files
*.mdf
*.ldf

# Windows and macOS
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JetBrains cleanup
*.sln.iml

# Node/npm if this project also has frontend assets
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
coverage/
